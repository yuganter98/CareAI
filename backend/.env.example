# Project
PROJECT_NAME="CareAI"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=careai_db
# Write the full URL explicitly — Python dotenv does not expand ${} variables
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/careai_db

# Security
# Generate your own key with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit the real .env file — it is listed in .gitignore
SECRET_KEY="REPLACE_WITH_GENERATED_KEY"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
UPLOAD_DIR="./uploads"

# AI Service Override
OPENAI_API_KEY="lm-studio"
OPENAI_API_BASE="http://localhost:1234/v1"

# CORS
ENVIRONMENT="development"
ALLOWED_ORIGINS=["http://localhost:3000"]
